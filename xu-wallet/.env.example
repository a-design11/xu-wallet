# ─── XU × RustOx Wallet — environment ──────────────────────────────────────
# Copy this file to `.env` and fill in the keys you have.
# Empty values fall back to public free endpoints so the wallet still works.

# ─── RustOx (first-party) ─────────────────────────────────────────────────
EXPO_PUBLIC_RUSTOX_RPC=https://rpc.rustox.io
EXPO_PUBLIC_RUSTOX_BACKUP_RPC=https://rpc-backup.rustox.io
EXPO_PUBLIC_RUSTOX_EXPLORER=https://explorer.rustox.io
EXPO_PUBLIC_RUSTOX_CHAIN_ID=21080

# ─── EVM RPCs ────────────────────────────────────────────────────────────
EXPO_PUBLIC_RPC_ETH=https://eth.llamarpc.com
EXPO_PUBLIC_RPC_BNB=https://bsc-dataseed.binance.org
EXPO_PUBLIC_RPC_POLYGON=https://polygon-rpc.com

# Alchemy / Infura (paid tiers — higher rate limits)
EXPO_PUBLIC_ALCHEMY_ETH_KEY=
EXPO_PUBLIC_ALCHEMY_POLY_KEY=
EXPO_PUBLIC_INFURA_KEY=

# ─── Solana ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_RPC_SOLANA=https://api.mainnet-beta.solana.com
EXPO_PUBLIC_HELIUS_API_KEY=

# ─── Prices ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_COINGECKO_API_KEY=

# ─── Explorers ────────────────────────────────────────────────────────────
EXPO_PUBLIC_ETHERSCAN_API_KEY=
EXPO_PUBLIC_BSCSCAN_API_KEY=
EXPO_PUBLIC_POLYGONSCAN_API_KEY=

# ─── Swap / WC ────────────────────────────────────────────────────────────
EXPO_PUBLIC_ONEINCH_KEY=
EXPO_PUBLIC_ZEROX_KEY=
EXPO_PUBLIC_WC_PROJECT_ID=

# ─── Security ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_INSTALL_SALT=xu-static-salt