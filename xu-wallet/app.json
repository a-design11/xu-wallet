{
  "expo": {
    "name": "XU Wallet",
    "slug": "xu-wallet",
    "version": "2.0.0",
    "orientation": "portrait",
    "scheme": "xuwallet",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0B0B0F",
      "resizeMode": "contain",
      "image": "./assets/splash.png"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.xuwallet.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "XU Wallet uses Face ID to unlock your wallet securely.",
        "NSCameraUsageDescription": "XU Wallet uses the camera to scan QR codes."
      }
    },
    "android": {
      "package": "com.xuwallet.app",
      "versionCode": 5,
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0F",
        "foregroundImage": "./assets/icon.png"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.INTERNET",
        "android.permission.CAMERA"
      ],
      "packageName": "com.xuwallet.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "XU Wallet uses Face ID to unlock your wallet securely."
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "XU Wallet uses the camera to scan QR codes for wallet addresses."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "root": "./app"
      },
      "eas": {
        "projectId": "9e96fad3-bc39-49d9-b5a7-ae16531c425c"
      }
    }
  }
}